APP_NAME="Pharma System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database — spin up with: docker compose up -d
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pharma
DB_USERNAME=pharma
DB_PASSWORD=secret

# JWT — generate with: php artisan tinker --execute="echo base64_encode(random_bytes(32));"
JWT_SECRET=
JWT_TTL=10080

CACHE_DRIVER=file
SESSION_DRIVER=database
SESSION_LIFETIME=120

QUEUE_CONNECTION=database

MAIL_MAILER=log
